{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemberResponse",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "role": {
      "type": "string",
      "enum": ["stratejist", "supheci", "yaratici", "muhendis", "realist"]
    },
    "stance": {
      "type": "string",
      "minLength": 1
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "flip_condition": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["role", "stance", "reasons", "confidence", "flip_condition"]
}
