# Claude Code (login auth, no API key)
CLAUDE_CODE_BIN=claude
MODEL_ATHENA=claude-opus-4-8
DIVAN_SKIP_CLAUDE=0

# Codex (login auth)
CODEX_BIN=codex
MODEL_SOCRATES=
MODEL_THEMIS_CODEX=

# Gemini / Antigravity CLI (login auth)
AGY_BIN=agy
MODEL_APOLLO=gemini-3.5-flash

# DeepSeek API - Hephaestus
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/chat/completions
MODEL_HEPHAESTUS=deepseek-v4-pro

# Local Ollama - Atlas
DIVAN_ENABLE_OLLAMA_ATLAS=1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BIN=ollama
OLLAMA_STOP_AFTER_RUN=1
MODEL_ATLAS=gemma4:12b
OLLAMA_TEMPERATURE_ATLAS=0.4
OLLAMA_TIMEOUT=240

# Backend / frontend
DIVAN_API_TIMEOUT=120
VITE_API_BASE_URL=http://localhost:8000
